{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
      "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../../lambdahack.github.io",
    "rootDir": "./src"
  },
  "include": ["src/**/*"]
}
