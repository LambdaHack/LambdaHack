{
  "name": "lambdahack-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Thin TypeScript terminal-emulator UI driving the LambdaHack wasm core",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/loader.ts --bundle --format=esm --outfile=dist/bundle.js --external:./ghc_wasm_jsffi.mjs && esbuild src/serve.ts --bundle --platform=node --format=esm --outfile=dist/serve.mjs"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.24",
    "typescript": "^5",
    "vitest": "^3"
  }
}
